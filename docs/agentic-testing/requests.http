### Project selection: backend/API - baseline
POST {{base_url}}/select-projects
Content-Type: application/json

{
  "context": {
    "title": "Backend Engineer",
    "description": "Build Python APIs with Django, PostgreSQL, Redis caching, authentication, Docker, Kubernetes, and AWS deployment."
  },
  "candidates": [
    {
      "id": "jobforge",
      "name": "JobForge Resume Engine",
      "summary": "FastAPI service that ranks skills and projects for job-targeted resumes with deterministic fallbacks.",
      "skills": {
        "technology": ["FastAPI", "PostgreSQL", "Docker", "AWS"],
        "programming": ["Python", "SQL"],
        "concepts": ["API", "Authentication", "Caching", "Deterministic Scoring"]
      }
    },
    {
      "id": "design-system",
      "name": "Design System Kit",
      "summary": "Reusable React components with tokens, accessibility checks, and Figma handoff.",
      "skills": {
        "technology": ["React", "TailwindCSS", "Figma"],
        "programming": ["TypeScript"],
        "concepts": ["Accessibility", "Design Systems", "UI Design"]
      }
    },
    {
      "id": "vision-lab",
      "name": "Vision Lab",
      "summary": "Image classification experiments with notebooks and training metrics.",
      "skills": {
        "technology": ["PyTorch", "Pandas"],
        "programming": ["Python"],
        "concepts": ["Machine Learning", "Data Visualization"]
      }
    }
  ],
  "top_n": 2,
  "dev_mode": true,
  "method": "baseline"
}

