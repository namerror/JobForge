{
  "schema_version": 1,
  "purpose": "Small agentic testing dataset for human-like review of JobForge API results without excessive token use.",
  "base_url": "http://127.0.0.1:8000",
  "skill_selection": {
    "endpoint": "/select-skills",
    "instructions": "Run each input set with the listed variants. Keep the input values identical within a set so method and baseline-filter behavior can be compared directly.",
    "input_sets": [
      {
        "id": "skills_backend_platform",
        "review_focus": "Backend/platform relevance, synonym normalization, and rejection of UI/game/data distractions.",
        "base_payload": {
          "job_role": "Backend Platform Engineer",
          "job_text": "Build reliable Python and Java services with REST APIs, PostgreSQL, Redis caching, Docker, Kubernetes, observability, authentication, rate limiting, and CI/CD on AWS.",
          "technology": [
            "React",
            "Django",
            "PostgreSQL",
            "Redis",
            "Docker",
            "Kubernetes",
            "AWS",
            "Figma",
            "PyTorch",
            "Unity"
          ],
          "programming": [
            "Python",
            "Java",
            "TypeScript",
            "C#",
            "Rust",
            "SQL"
          ],
          "concepts": [
            "REST",
            "API",
            "Authentication",
            "Rate Limiting",
            "Caching",
            "CI/CD",
            "Observability",
            "UI Design",
            "Machine Learning"
          ],
          "top_n": 4,
          "dev_mode": true
        },
        "variants": [
          {
            "id": "baseline",
            "method": "baseline",
            "baseline_filter": false
          },
          {
            "id": "llm_no_filter",
            "method": "llm",
            "baseline_filter": false
          },
          {
            "id": "llm_with_filter",
            "method": "llm",
            "baseline_filter": true
          },
          {
            "id": "embeddings_with_filter",
            "method": "embeddings",
            "baseline_filter": true
          }
        ],
        "expected_review_anchors": {
          "strong": {
            "technology": ["Django", "PostgreSQL", "Redis", "Docker", "Kubernetes", "AWS"],
            "programming": ["Python", "Java", "SQL"],
            "concepts": ["REST", "API", "Authentication", "Rate Limiting", "Caching", "CI/CD", "Observability"]
          },
          "weak_or_distractor": {
            "technology": ["React", "Figma", "PyTorch", "Unity"],
            "programming": ["C#"],
            "concepts": ["UI Design", "Machine Learning"]
          }
        }
      },
      {
        "id": "skills_frontend_product",
        "review_focus": "Frontend/product relevance, category boundaries, and whether backend/cloud skills are deprioritized.",
        "base_payload": {
          "job_role": "Frontend Product Engineer",
          "job_text": "Create accessible TypeScript React interfaces with design systems, state management, performance profiling, GraphQL integration, testing, and close collaboration with designers.",
          "technology": [
            "React",
            "Next.js",
            "TailwindCSS",
            "Figma",
            "GraphQL",
            "Django",
            "Kubernetes",
            "AWS",
            "Pandas",
            "PostgreSQL"
          ],
          "programming": [
            "TypeScript",
            "JavaScript",
            "Python",
            "Java",
            "SQL",
            "Go"
          ],
          "concepts": [
            "Accessibility",
            "Design Systems",
            "State Management",
            "Performance Optimization",
            "Testing",
            "API",
            "Database Management",
            "Distributed Computing"
          ],
          "top_n": 4,
          "dev_mode": true
        },
        "variants": [
          {
            "id": "baseline",
            "method": "baseline",
            "baseline_filter": false
          },
          {
            "id": "llm_no_filter",
            "method": "llm",
            "baseline_filter": false
          },
          {
            "id": "llm_with_filter",
            "method": "llm",
            "baseline_filter": true
          },
          {
            "id": "embeddings_with_filter",
            "method": "embeddings",
            "baseline_filter": true
          }
        ],
        "expected_review_anchors": {
          "strong": {
            "technology": ["React", "Next.js", "TailwindCSS", "Figma", "GraphQL"],
            "programming": ["TypeScript", "JavaScript"],
            "concepts": ["Accessibility", "Design Systems", "State Management", "Performance Optimization", "Testing", "API"]
          },
          "weak_or_distractor": {
            "technology": ["Django", "Kubernetes", "AWS", "Pandas"],
            "programming": ["Java", "Go"],
            "concepts": ["Database Management", "Distributed Computing"]
          }
        }
      }
    ]
  },
  "project_selection": {
    "endpoint": "/select-projects",
    "instructions": "Run each input set with baseline and llm variants. Candidate lists are intentionally short but include plausible distractors.",
    "input_sets": [
      {
        "id": "projects_backend_api",
        "review_focus": "Select backend API evidence over visually impressive but less relevant frontend or ML projects.",
        "base_payload": {
          "context": {
            "title": "Backend Engineer",
            "description": "Build Python APIs with Django, PostgreSQL, Redis caching, authentication, Docker, Kubernetes, and AWS deployment."
          },
          "candidates": [
            {
              "id": "jobforge",
              "name": "JobForge Resume Engine",
              "summary": "FastAPI service that ranks skills and projects for job-targeted resumes with deterministic fallbacks.",
              "skills": {
                "technology": ["FastAPI", "PostgreSQL", "Docker", "AWS"],
                "programming": ["Python", "SQL"],
                "concepts": ["API", "Authentication", "Caching", "Deterministic Scoring"]
              }
            },
            {
              "id": "design-system",
              "name": "Design System Kit",
              "summary": "Reusable React components with tokens, accessibility checks, and Figma handoff.",
              "skills": {
                "technology": ["React", "TailwindCSS", "Figma"],
                "programming": ["TypeScript"],
                "concepts": ["Accessibility", "Design Systems", "UI Design"]
              }
            },
            {
              "id": "vision-lab",
              "name": "Vision Lab",
              "summary": "Image classification experiments with notebooks and training metrics.",
              "skills": {
                "technology": ["PyTorch", "Pandas"],
                "programming": ["Python"],
                "concepts": ["Machine Learning", "Data Visualization"]
              }
            }
          ],
          "top_n": 2,
          "dev_mode": true
        },
        "variants": [
          {
            "id": "baseline",
            "method": "baseline"
          },
          {
            "id": "llm",
            "method": "llm"
          }
        ],
        "expected_review_anchors": {
          "best_fit": ["jobforge"],
          "acceptable_second_fit": ["vision-lab", "design-system"],
          "notes": "jobforge should be first. The second slot is less important, but the report should explain why the chosen runner-up is weaker."
        }
      },
      {
        "id": "projects_frontend_product",
        "review_focus": "Select frontend/product evidence over backend infrastructure and ML projects.",
        "base_payload": {
          "context": {
            "title": "Frontend Product Engineer",
            "description": "Build accessible React and TypeScript product flows, integrate GraphQL APIs, improve performance, maintain design systems, and write UI tests."
          },
          "candidates": [
            {
              "id": "design-system",
              "name": "Design System Kit",
              "summary": "Reusable React components with tokens, accessibility checks, and Figma handoff.",
              "skills": {
                "technology": ["React", "Next.js", "TailwindCSS", "Figma", "GraphQL"],
                "programming": ["TypeScript", "JavaScript"],
                "concepts": ["Accessibility", "Design Systems", "Testing", "Performance Optimization"]
              }
            },
            {
              "id": "jobforge",
              "name": "JobForge Resume Engine",
              "summary": "FastAPI service that ranks skills and projects for job-targeted resumes with deterministic fallbacks.",
              "skills": {
                "technology": ["FastAPI", "Docker", "AWS"],
                "programming": ["Python", "SQL"],
                "concepts": ["API", "Deterministic Scoring", "Caching"]
              }
            },
            {
              "id": "analytics-pipeline",
              "name": "Analytics Pipeline",
              "summary": "Batch data pipeline for dashboards and model-ready datasets.",
              "skills": {
                "technology": ["Pandas", "PostgreSQL", "AWS"],
                "programming": ["Python", "SQL"],
                "concepts": ["Data Visualization", "ETL", "Database Management"]
              }
            }
          ],
          "top_n": 2,
          "dev_mode": true
        },
        "variants": [
          {
            "id": "baseline",
            "method": "baseline"
          },
          {
            "id": "llm",
            "method": "llm"
          }
        ],
        "expected_review_anchors": {
          "best_fit": ["design-system"],
          "acceptable_second_fit": ["jobforge", "analytics-pipeline"],
          "notes": "design-system should be first. jobforge can be justified as API-adjacent; analytics-pipeline should only rank high if data/dashboard framing is strongly credited."
        }
      }
    ]
  }
}
